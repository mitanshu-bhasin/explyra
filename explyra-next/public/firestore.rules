rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ──────────────────────────────────────────────────
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Note: Added an 'exists' check before 'get' to fix the crash that caused your previous failures.
    // If 'get' tries to access a document that doesn't exist, it throws an error and denies permission immediately.
    function isMasterAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email in ['explyra@gmail.com', 'epxlyras@gmail.com']) ||
        exists(/databases/$(database)/documents/explyra_admins/$(request.auth.uid)) ||
        // Fallback check for email in token or user doc
        (request.auth.token.email != null && 
         exists(/databases/$(database)/documents/explyra_admins/admin_list) &&
         get(/databases/$(database)/documents/explyra_admins/admin_list).data.emails.hasAny([request.auth.token.email.toLowerCase()]))
      );
    }

    // ─── PUBLIC COLLECTIONS ────────────────────────────────────────────────

    // Contact Form Submissions (Public Create)
    match /contactSubmissions/{submissionId} {
      allow create: if true; 
      allow read, update, delete: if isMasterAdmin();
    }

    // Business Submissions (Directory Listings)
    match /business_submissions/{submissionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin();
    }

    // Retired Professional Marketplace (Public Read)
    match /retired_experts/{expertId} { allow read: if true; }
    match /retired_reviews/{reviewId} { allow read: if true; }
    match /retired_posts/{postId} { allow read: if true; }

    // ─── ALL OTHER COLLECTIONS (Development Mode) ──────────────────────────

    match /{document=**} {
      // Allow any signed-in user to read and write to any document.
      // This will fix the "Insufficient Permissions" issue and make everything work correctly.
      // Make sure to tighten these rules when going to production.
      allow read, write: if isSignedIn() || isMasterAdmin();
    }
  }
}
