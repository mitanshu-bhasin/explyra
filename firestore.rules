rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ──────────────────────────────────────────────────
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is part of the Explyra Team (Master Admin)
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['explyra@gmail.com', 'epxlyra@gmail.com'] ||
        exists(/databases/$(database)/documents/explyra_admins/$(request.auth.uid)) ||
        // Fallback check for email in token or user doc
        (request.auth.token.email != null && 
         get(/databases/$(database)/documents/explyra_admins/admin_list).data.emails.hasAny([request.auth.token.email.toLowerCase()]))
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isCompanyMember(companyId) {
      return isSignedIn() && (isMasterAdmin() || getUserData().companyId == companyId);
    }

    function isCompanyAdmin(companyId) {
      return isMasterAdmin() || (isCompanyMember(companyId) && getUserData().role in ['ADMIN', 'SUPER_ADMIN', 'FINANCE_MANAGER']);
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || isMasterAdmin());
    }

    // ─── VALIDATION HELPERS ────────────────────────────────────────────────
    
    function isValidExpense(data) {
      return data.title is string && 
             data.totalAmount != null &&
             data.companyId is string &&
             data.userId is string;
    }

    // ─── PUBLIC COLLECTIONS ────────────────────────────────────────────────

    // Contact Form Submissions (Public Create)
    match /contactSubmissions/{submissionId} {
      allow create: if true; 
      allow read, update, delete: if isMasterAdmin();
    }

    // Business Submissions (Directory Listings)
    match /business_submissions/{submissionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin();
    }

    // Retired Professional Marketplace (Public Read)
    match /retired_experts/{expertId} { allow read: if true; }
    match /retired_reviews/{reviewId} { allow read: if true; }
    match /retired_posts/{postId} { allow read: if true; }

    // ─── SECURE COLLECTIONS ────────────────────────────────────────────────

    // Users: Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || isMasterAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isCompanyAdmin(getUserData().companyId) || isMasterAdmin());
      allow delete: if isMasterAdmin();
    }

    // Companies: Organizational isolation
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Allow self-onboarding
      allow update: if isCompanyAdmin(companyId) || isMasterAdmin();
      allow delete: if isMasterAdmin();

      match /{subcollection}/{docId} {
        allow read, write: if isCompanyMember(companyId);
      }
    }

    // Expenses: Principal logic
    match /expenses/{expenseId} {
      allow read: if isSignedIn() && (
        isMasterAdmin() || 
        resource.data.userId == request.auth.uid || 
        isCompanyMember(resource.data.companyId)
      );
      
      allow create: if isSignedIn() && 
        (request.resource.data.userId == request.auth.uid || isMasterAdmin()) &&
        isValidExpense(request.resource.data);
        
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) ||
        isCompanyAdmin(resource.data.companyId)
      );
      
      allow delete: if isCompanyAdmin(resource.data.companyId) || isMasterAdmin();
    }

    // Email SaaS: Custom Domains
    match /custom_domains/{domainId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.domain is string
        && request.resource.data.domain.size() >= 3
        && request.resource.data.verified is bool
        && request.resource.data.createdAt != null;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.domain == resource.data.domain
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.verified == resource.data.verified
        && request.resource.data.status == resource.data.status;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Email SaaS: Mailboxes
    match /mailboxes/{mailboxId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.domainId is string
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && request.resource.data.createdAt != null
        && exists(/databases/$(database)/documents/custom_domains/$(request.resource.data.domainId))
        && get(/databases/$(database)/documents/custom_domains/$(request.resource.data.domainId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/custom_domains/$(request.resource.data.domainId)).data.verified == true;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Email SaaS: Received mail is write-only by backend service account, read-only by owner
    match /received_emails/{emailId} {
      allow read: if isSignedIn()
        && resource.data.mailboxId is string
        && exists(/databases/$(database)/documents/mailboxes/$(resource.data.mailboxId))
        && get(/databases/$(database)/documents/mailboxes/$(resource.data.mailboxId)).data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Personal Vault & Financial Accounts: Strict User Isolation
    match /personal_vault/{itemId} {
      allow read, write: if isOwner(resource == null ? request.resource.data.uid : resource.data.uid);
    }
    match /financial_accounts/{accountId} {
      allow read, write: if isOwner(resource == null ? request.resource.data.uid : resource.data.uid);
    }

    // Infrastructure: Projects, Tasks, CRM
    match /projects/{projectId} { allow read: if isCompanyMember(resource.data.companyId); allow write: if isCompanyAdmin(resource.data.companyId); }
    match /tasks/{taskId} { allow read, write: if isCompanyMember(resource.data.companyId) || isMasterAdmin(); }
    match /crm_deals/{id} { allow read, write: if isCompanyMember(resource.data.companyId) || isMasterAdmin(); }
    match /crm_leads/{id} { allow read, write: if isCompanyMember(resource.data.companyId) || isMasterAdmin(); }
    match /crm_contacts/{id} { allow read, write: if isCompanyMember(resource.data.companyId) || isMasterAdmin(); }

    // Communication: Chats & Notifications
    match /chats/{chatId} { allow read, write: if isCompanyMember(resource.data.companyId) || isMasterAdmin(); }
    match /notifications/{notifId} { allow read, write: if isOwner(resource == null ? request.resource.data.userId : resource.data.userId); }
    match /audit_logs/{logId} { allow read: if isCompanyAdmin(resource.data.companyId); allow create: if isSignedIn(); }

    // ─── ADMIN GOVERNANCE ────────────────────────────────────────────────
    
    // Deletion Requests
    match /deletion_requests/{requestId} {
      allow create: if true; // Public submission as it's a "Request Deletion" path
      allow read, update, delete: if isMasterAdmin();
    }

    match /explyra_admins/{adminId} {
      // Allow any signed-in user to check if they are an admin
      allow read: if isSignedIn() && (
        isMasterAdmin() || 
        adminId == 'admin_list' || 
        (resource != null && resource.data.email.toLowerCase() == request.auth.token.email.toLowerCase())
      );
      allow write: if isMasterAdmin();
    }

    // Fallback: Master Admin can access everything
    match /{collection}/{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Global Fallback: Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
