rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Explyra Directories - Business Submissions
    match /business_submissions/{submissionId} {
      allow read: if true; // Public can view approved listings
      allow create: if request.auth != null; // Authenticated users can submit
      allow update, delete: if request.auth != null && 
        (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'MASTER_ADMIN');
    }

    // ─── Helper Functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCompanyMember(companyId) {
      return isSignedIn() && getUserData().companyId == companyId;
    }

    function isCompanyAdmin(companyId) {
      return isCompanyMember(companyId) && getUserData().role in ['ADMIN', 'SUPER_ADMIN'];
    }

    // ─── Users Collection ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read any user profile if signed in (for search/collaboration)
      allow read: if isSignedIn();
      // Only the user themselves or an admin can create/update profiles
      allow create: if isSignedIn() && (request.auth.uid == userId || getUserData().role == 'ADMIN');
      allow update: if isSignedIn() && (request.auth.uid == userId || getUserData().role == 'ADMIN');
      allow delete: if isSignedIn() && getUserData().role == 'ADMIN';
    }

    // ─── Companies Collection ──────────────────────────────────────────────────
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isCompanyAdmin(companyId);
      allow delete: if false; // Deletion restricted

      // Company subcollections (inventory, invoices, customers, etc)
      match /{subcollection}/{docId} {
        allow read, write: if isCompanyMember(companyId);
      }
    }

    // ─── Company Members Collection ────────────────────────────────────────────
    match /companyMembers/{memberId} {
      allow read: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow write: if isSignedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid) || 
        isCompanyAdmin(resource.data.companyId)
      );
    }

    // ─── Expenses Collection ───────────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow read: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && isCompanyMember(request.resource.data.companyId);
      allow update, delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid || 
        isCompanyAdmin(resource.data.companyId)
      );
    }

    // ─── Projects Collection ───────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow write: if isSignedIn() && isCompanyAdmin(resource.data.companyId);
    }

    // ─── Tasks Collection ──────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assignedTo == request.auth.uid || 
        resource.data.assignedBy == request.auth.uid || 
        isCompanyAdmin(resource.data.companyId)
      );
      allow write: if isSignedIn() && (
        request.resource.data.assignedBy == request.auth.uid || 
        isCompanyAdmin(request.resource.data.companyId)
      );
    }

    // ─── CRM Collections ───────────────────────────────────────────────────────
    match /crm_deals/{dealId} {
      allow read, write: if isSignedIn() && (
        (resource != null && isCompanyMember(resource.data.companyId)) ||
        (resource == null && isCompanyMember(request.resource.data.companyId))
      );
    }
    match /crm_leads/{leadId} {
      allow read, write: if isSignedIn() && (
        (resource != null && isCompanyMember(resource.data.companyId)) ||
        (resource == null && isCompanyMember(request.resource.data.companyId))
      );
    }
    match /crm_contacts/{contactId} {
      allow read, write: if isSignedIn() && (
        (resource != null && isCompanyMember(resource.data.companyId)) ||
        (resource == null && isCompanyMember(request.resource.data.companyId))
      );
    }

    // ─── Personal Vault: Strict User Isolation ─────────────────────────────────
    match /personal_vault/{itemId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ─── Settings (Global/Branding) ────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getUserData().role in ['ADMIN', 'SUPER_ADMIN'];
    }

    // ─── Chats & Global Chat ───────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (
        (resource != null && isCompanyMember(resource.data.companyId)) ||
        (resource == null && isCompanyMember(request.resource.data.companyId))
      );
      
      match /messages/{msgId} {
         allow read: if isSignedIn();
         allow create: if isSignedIn();
      }
    }

    match /global_chat/{messageId} {
      allow read: if isSignedIn() && isCompanyMember(resource.data.companyId);
      allow create: if isSignedIn() && isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyAdmin(resource.data.companyId);
    }

    // ─── Calling Signaling ─────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read, write: if isSignedIn() && (
        (resource != null && (resource.data.caller == request.auth.uid || resource.data.receiver == request.auth.uid)) ||
        (resource == null && request.resource.data.caller == request.auth.uid)
      );
    }

    // ─── Workflow & Audit Collections ──────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isCompanyAdmin(resource.data.companyId);
      allow create: if isSignedIn(); // System generated logs
    }

    // ─── Retired Professionals Marketplace ─────────────────────────────────────
    match /retired_users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /retired_experts/{expertId} {
      allow read: if true; 
      allow create, update: if isOwner(expertId);
      allow delete: if isOwner(expertId) || getUserData().role == 'ADMIN';
    }

    match /retired_bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.expertId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.expertId == request.auth.uid);
    }

    match /retired_reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /retired_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.authorId);
    }

    match /retired_chats/{chatId} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      
      match /messages/{msgId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/retired_chats/$(chatId)).data.participants;
        allow create: if isSignedIn();
      }
    }

    // ─── Fallback: Deny everything else ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
