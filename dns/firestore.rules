rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Subdomains collection
    match /subdomains/{subdomain} {
      allow read: if true; // Publicly readable for availability checks
      allow create: if request.auth != null && 
                    !exists(/databases/$(database)/documents/subdomains/$(subdomain));
      allow update, delete: if request.auth != null && 
                            resource.data.owner == request.auth.uid;
    }

    // DNS Records collection
    match /dns_records/{recordId} {
      allow read: if request.auth != null && 
                  resource.data.owner == request.auth.uid;
      allow create: if request.auth != null && 
                    request.resource.data.owner == request.auth.uid;
      allow update, delete: if request.auth != null && 
                            resource.data.owner == request.auth.uid;
    }
  }
}
