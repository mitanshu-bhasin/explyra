# NOWPayments secret API key (required)
NOWPAYMENTS_API_KEY=

# Optional: validate NOWPayments webhook signatures
NOWPAYMENTS_IPN_SECRET=

# Local API server port
PORT=8787

# Public website URL for redirects after payment
PUBLIC_SITE_URL=http://localhost:8787

# Public API URL used in NOWPayments IPN callback URL
PUBLIC_API_URL=http://localhost:8787

# Optional: sync paid state to Firestore user documents
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
