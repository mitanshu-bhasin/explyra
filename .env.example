# =============================================================================
# Root static site + Cloudflare Pages: copy to .env and run `node scripts/sync-env.js`
# to generate js/env.js. Set the same keys in Cloudflare Pages → Environment variables
# (build) for production deploys.
# =============================================================================

# Firebase (client config; safe to expose in frontend — still prefer env per environment)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Google Analytics (Measurement ID)
GA_MEASUREMENT_ID=

# Cloudflare (zone id for DNS/email features; tokens stay in Functions secrets)
CLOUDFLARE_ZONE_ID=

# ImageKit uploads (public key)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_URL=https://upload.imagekit.io/api/v1/files/upload

# EmailJS (public key only)
EMAILJS_PUBLIC_KEY=

# =============================================================================
# NOWPayments (crypto payments server / Functions)
# =============================================================================
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
PORT=8787
PUBLIC_SITE_URL=http://localhost:8787
PUBLIC_API_URL=http://localhost:8787
USD_INR_RATE=83

# =============================================================================
# Cloudflare Pages Functions (set in Pages → Settings → Environment variables / Secrets)
# =============================================================================
# Comma-separated browser origins allowed to call API routes (CORS)
ALLOWED_ORIGINS=https://explyra.me,https://www.explyra.me

GROQ_API_KEY=
GEMINI_API_KEY=
IMGBB_KEY=
RESEND_API_KEY=
CLOUDFLARE_API_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
