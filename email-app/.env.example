# Cloudflare
CLOUDFLARE_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Resend
RESEND_API_KEY=your_resend_api_key

# Firebase Admin (paste stringified service account JSON)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Webhook secret shared between Cloudflare Worker and Vercel API
WEBHOOK_SECRET=generate_a_random_secret_here

# Email domain for sending (e.g. yourdomain.com)
EMAIL_DOMAIN=explyra.me

# Outbound worker used for credential delivery emails
OUTBOUND_WORKER_URL=https://email-worker.mfskufgu.workers.dev
