rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection
    match /users/{userId} {
      // Users can only read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Labours Collection
    match /labours/{labourId} {
      // Anyone authenticated can read online labourers (for map discovery)
      allow read: if request.auth != null && resource.data.isOnline == true;
      
      // Labours can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == labourId;
    }
    
    // Bookings / Hits
    match /bookings/{bookingId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.labourId == request.auth.uid);
    }
  }
}
