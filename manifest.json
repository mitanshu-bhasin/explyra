{
  "name": "Explyra",
  "short_name": "Explyra",
  "id": "/?source=pwa",
  "description": "The official portal for Explyra. Streamline your operations with our secure, efficient tools.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "minimal-ui"
  ],
  "orientation": "portrait-primary",
  "background_color": "#f8fafc",
  "theme_color": "#1546C0",
  "prefer_related_applications": false,
  "related_applications": [],
  "handle_links": "preferred",
  "categories": [
    "productivity",
    "finance",
    "business"
  ],
  "lang": "en-US",
  "dir": "ltr",
  "icons": [
    {
      "src": "favicon-32x32.png",
      "sizes": "32x32",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "assets/images/explyra_screenshot_1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Comprehensive Dashboard Overview"
    },
    {
      "src": "assets/images/explyra_screenshot_2.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Simple Expense Submission"
    }
  ],
  "shortcuts": [
    {
      "name": "Submit Claim",
      "short_name": "New Claim",
      "description": "Create a new expense claim instantly",
      "url": "./emp.html?action=create",
      "icons": [
        {
          "src": "android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Admin Panel",
      "short_name": "Admin",
      "description": "Access administrative controls",
      "url": "./admin.html",
      "icons": [
        {
          "src": "android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Check Mail",
      "short_name": "MailBox",
      "description": "Access your Explyra MailBox",
      "url": "./mailbox",
      "icons": [
        {
          "src": "android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "widgets": [
    {
      "name": "Expense Summary",
      "description": "Quick view of your recent expenses and balance.",
      "tag": "expense-summary",
      "ms_ac_template": "expense-summary.json",
      "data": "expense-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "assets/images/widget-preview.png",
          "sizes": "600x400",
          "type": "image/png",
          "label": "Expense Summary Widget"
        }
      ],
      "icons": [
        {
          "src": "android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "share_target": {
    "action": "./emp.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "receipt",
          "accept": [
            "image/jpeg",
            "image/png",
            "application/pdf"
          ]
        }
      ]
    }
  }
}