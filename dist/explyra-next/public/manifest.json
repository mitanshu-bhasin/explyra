{
  "name": "Explyra — The All-in-One SaaS Ecosystem",
  "short_name": "Explyra",
  "id": "/?source=pwa",
  "description": "The official portal for Explyra. Streamline your operations with our secure, efficient tools for expense management, CRM, and team productivity.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "minimal-ui"
  ],
  "orientation": "any",
  "background_color": "#f8fafc",
  "theme_color": "#1546C0",
  "prefer_related_applications": false,
  "related_applications": [],
  "handle_links": "preferred",
  "categories": [
    "productivity",
    "finance",
    "business",
    "developer tools",
    "utilities"
  ],
  "lang": "en-US",
  "dir": "ltr",
  "icons": [
    {
      "src": "favicon-32x32.png",
      "sizes": "32x32",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "assets/images/explyra_screenshot_1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Explyra Dashboard on Desktop"
    },
    {
      "src": "assets/images/explyra_screenshot_2.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Explyra Mobile Experience"
    }
  ],
  "shortcuts": [
    {
      "name": "Submit Claim",
      "short_name": "New Claim",
      "description": "Create a new expense claim instantly",
      "url": "./emp.html?action=create",
      "icons": [{ "src": "android-chrome-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Admin Panel",
      "short_name": "Admin",
      "description": "Access administrative controls",
      "url": "./admin.html",
      "icons": [{ "src": "android-chrome-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "AI Assistant",
      "short_name": "AI",
      "description": "Chat with Explyra AI",
      "url": "./ai-dashboard.html",
      "icons": [{ "src": "android-chrome-192x192.png", "sizes": "192x192" }]
    }
  ],
  "widgets": [
    {
      "name": "Recent Activity",
      "description": "Quick view of your recent expenses.",
      "tag": "activity",
      "ms_ac_template": "expense-summary.json",
      "data": "expense-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "assets/images/explyra_logo.png",
          "sizes": "512x512",
          "type": "image/png",
          "label": "Widget Preview"
        }
      ],
      "icons": [{ "src": "android-chrome-192x192.png", "sizes": "192x192" }]
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "share_target": {
    "action": "./emp.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "receipt",
          "accept": ["image/jpeg", "image/png", "application/pdf"]
        }
      ]
    }
  }
}
