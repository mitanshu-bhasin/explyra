{
    "type": "AdaptiveCard",
    "body": [
        {
            "type": "TextBlock",
            "size": "Medium",
            "weight": "Bolder",
            "text": "Explyra Expense Summary",
            "color": "Accent"
        },
        {
            "type": "FactSet",
            "facts": [
                {
                    "title": "Monthly Total:",
                    "value": "${total}"
                },
                {
                    "title": "Remaining Budget:",
                    "value": "${budget}"
                },
                {
                    "title": "Recent:",
                    "value": "${recent}"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Action.Execute",
            "title": "Refresh",
            "verb": "refresh"
        },
        {
            "type": "Action.OpenUrl",
            "title": "Open Dashboard",
            "url": "https://explyra.me/emp.html"
        }
    ],
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.5"
}
