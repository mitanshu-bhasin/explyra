{
  "name": "Explyra",
  "short_name": "Explyra",
  "id": "/?source=pwa",
  "description": "The official portal for Explyra. Streamline your operations with our secure, efficient tools.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "tabbed",
    "minimal-ui"
  ],
  "orientation": "portrait-primary",
  "background_color": "#f8fafc",
  "theme_color": "#1546C0",
  "prefer_related_applications": false,
  "related_applications": [],
  "handle_links": "preferred",
  "categories": [
    "finance",
    "business",
    "productivity",
    "utilities"
  ],
  "lang": "en-US",
  "dir": "ltr",
  "icons": [
    {
      "src": "assets/images/explyra_logo.png",
      "sizes": "32x32",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/images/explyra_logo.png",
      "sizes": "192x192",
      "type": "image/jpeg",
      "purpose": "any maskable"
    },
    {
      "src": "assets/images/explyra_logo.png",
      "sizes": "512x512",
      "type": "image/jpeg",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "assets/images/explyra_screenshot_1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Comprehensive Dashboard Overview"
    },
    {
      "src": "assets/images/explyra_screenshot_2.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Simple Expense Submission"
    }
  ],
  "shortcuts": [
    {
      "name": "Submit Claim",
      "short_name": "New Claim",
      "description": "Create a new expense claim instantly",
      "url": "./emp.html?action=create",
      "icons": [
        {
          "src": "assets/images/explyra_logo.png",
          "sizes": "192x192",
          "type": "image/jpeg"
        }
      ]
    },
    {
      "name": "Admin Panel",
      "short_name": "Admin",
      "description": "Access administrative controls",
      "url": "./admin.html",
      "icons": [
        {
          "src": "assets/images/explyra_logo.png",
          "sizes": "192x192",
          "type": "image/jpeg"
        }
      ]
    }
  ],
  "launch_handler": {
    "client_mode": [
      "focus-existing",
      "auto"
    ]
  },
  "edge_side_panel": {
    "preferred_width": 480
  },
  "share_target": {
    "action": "/emp.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "receipt",
          "accept": [
            "image/jpeg",
            "image/png",
            "application/pdf"
          ]
        }
      ]
    }
  },
  "iarc_rating_id": "e58c735d-dead-4f2e-836e-58742d1396a5",
  "scope_extensions": [
    {
      "origin": "https://explyra.me"
    },
    {
      "origin": "https://www.explyra.me"
    },
    {
      "origin": "https://*.explyra.me"
    }
  ],
  "file_handlers": [
    {
      "action": "/emp.html?action=import",
      "accept": {
        "application/json": [
          ".json"
        ],
        "text/csv": [
          ".csv"
        ]
      },
      "icons": [
        {
          "src": "android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+explyra",
      "url": "/?url=%s"
    }
  ],
  "note_taking": {
    "new_note_url": "/emp.html?action=new-note"
  },
  "widgets": [
    {
      "name": "Recent Activity",
      "short_name": "Activity",
      "description": "Quick view of your recent expenses.",
      "tag": "activity",
      "ms_ac_template": "/expense-summary.json",
      "data": "/expense-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/assets/images/explyra_logo.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ],
      "icons": [
        {
          "src": "/android-chrome-192x192.png",
          "sizes": "192x192"
        }
      ]
    }
  ]
}